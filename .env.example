# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/recipe-finder

# JWT
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Gemini AI (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Spoonacular (get from https://spoonacular.com/food-api)
SPOONACULAR_API_KEY=your-spoonacular-api-key-here
